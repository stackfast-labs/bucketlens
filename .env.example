# BucketLens — A media-first browser for R2 and S3-compatible buckets.

PORT=3117
APP_TITLE=BucketLens
DEMO_MODE=false

# Storage: Cloudflare R2 / AWS S3 / MinIO / Wasabi / B2 / Spaces / generic S3-compatible.
S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
S3_REGION=auto
S3_FORCE_PATH_STYLE=true
S3_ACCESS_KEY_ID=[REDACTED]
S3_SECRET_ACCESS_KEY=[REDACTED]
S3_BUCKET=my-media-bucket

# Optional scope. Empty means browse the whole bucket.
S3_PREFIX=

# Public base URL used for Copy URL / Copy Markdown. No trailing slash.
PUBLIC_BASE_URL=https://assets.example.com

# Safety controls. BucketLens has no built-in auth by default.
# Put it inside Tailscale, behind Cloudflare Zero Trust Access, or behind a trusted reverse proxy/auth gateway.
READ_ONLY=false
ALLOW_UPLOAD=true
ALLOW_DELETE=false
ALLOW_FOLDER_CREATE=true

# Optional lightweight token guard. Not a replacement for production auth/access control.
APP_TOKEN=

MAX_UPLOAD_BYTES=21474836480
CACHE_DIR=.cache
