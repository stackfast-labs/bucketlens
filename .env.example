PORT=3117
APP_TITLE=AbSim Assets

# Cloudflare R2 / S3-compatible connection
S3_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
S3_REGION=auto
S3_ACCESS_KEY_ID=[REDACTED]
S3_SECRET_ACCESS_KEY=[REDACTED]
S3_BUCKET=absim-assets
S3_FORCE_PATH_STYLE=true

# Prefix this app is allowed to browse/manage. No leading slash. Empty = whole bucket.
S3_PREFIX=

# Public URL base used for copy buttons. No trailing slash.
PUBLIC_BASE_URL=https://absim-assets.mlw88.net

# Optional simple gate. If set, requests require header X-R2-Browser-Token or ?token=...
APP_TOKEN=

# Upload cap in bytes. Default shown = 20 GiB.
MAX_UPLOAD_BYTES=21474836480

# Thumbnail cache directory inside container. Mount as volume in Docker.
CACHE_DIR=/app/.cache
