{
  "name": "bucketlens",
  "version": "0.1.0",
  "description": "A media-first browser for R2 and S3-compatible buckets.",
  "type": "module",
  "license": "MIT",
  "author": "StackFast",
  "repository": {
    "type": "git",
    "url": "https://github.com/stackfast/bucketlens.git"
  },
  "homepage": "https://github.com/stackfast/bucketlens#readme",
  "bugs": {
    "url": "https://github.com/stackfast/bucketlens/issues"
  },
  "keywords": [
    "cloudflare-r2",
    "s3",
    "object-storage",
    "media-browser",
    "asset-management",
    "mcp",
    "dokploy",
    "self-hosted"
  ],
  "bin": {
    "bucketlens": "bin/bucketlens.js"
  },
  "scripts": {
    "start": "node server.js",
    "serve": "node server.js",
    "dev": "NODE_ENV=development node server.js",
    "cli": "node bin/bucketlens.js",
    "mcp": "node src/mcp/server.js",
    "lint": "node --check server.js && node --check bin/bucketlens.js && node --check src/server.js && node --check src/config.js && node --check src/storage.js && node --check src/media.js && node --check src/mcp/server.js && node --check public/app.js",
    "test": "node --test",
    "check": "npm run lint && npm test",
    "docker:build": "docker build -t bucketlens:test ."
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.935.0",
    "@aws-sdk/lib-storage": "^3.935.0",
    "@aws-sdk/s3-request-presigner": "^3.935.0",
    "busboy": "^1.6.0",
    "express": "^4.21.2",
    "mime-types": "^2.1.35",
    "sharp": "^0.33.5"
  },
  "engines": {
    "node": ">=20"
  }
}
